@model WebApplication1.Models.HomeViewModel


@{
    ViewData["Title"] = "Xe tự lái";
}

<div class="container-fluid mt-4 px-md-5">
    <h2 class="text-center mb-5 fw-bold" style="color: #333; font-size: 1.5rem; text-transform: uppercase;">Danh sách xe tự lái cho thuê</h2>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @{
            var fullList = new List<dynamic> {
                // Hàng 1
                new { Name = "Mercedes Benz E300 AMG", Price = 3500000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "BMW 520i Luxury Line", Price = 3200000, Year = "2021", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Audi A6 Premium", Price = 3000000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Camry 2.5Q", Price = 1500000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },

                // Hàng 2
                new { Name = "Kia Carnival Signature", Price = 2500000, Year = "2024", Gear = "Tự động", Fuel = "Dầu", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTLtKpqMQ3gOLVi6hkYkI1bpMSlFYvigWNUBQ&s" },
                new { Name = "Hyundai SantaFe Premium", Price = 1600000, Year = "2022", Gear = "Tự động", Fuel = "Dầu", Seats = 7, Img = "data:image/jpeg;base64," },
                new { Name = "Toyota Fortuner Legender", Price = 1400000, Year = "2021", Gear = "Tự động", Fuel = "Dầu", Seats = 7, Img = "data:image/jpeg;base64," },
                new { Name = "Ford Everest Titanium", Price = 1700000, Year = "2023", Gear = "Tự động", Fuel = "Dầu", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ0VX-4HTCrTM2mZ4BArn6-5LDwDT4BfPlu_w&s" },

                // Hàng 3
                new { Name = "Mazda CX-5 Premium", Price = 1200000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Hyundai Tucson Turbo", Price = 1300000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRfHZlBidGwRzNRRxMh5ZktuFRF9AIqe7OF4Q&s" },
                new { Name = "Honda CR-V L", Price = 1400000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "data:image/jpeg;base64," },
                new { Name = "VinFast Lux SA2.0", Price = 1500000, Year = "2021", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "data:image/jpeg;base64," },

                // Hàng 4
                new { Name = "Mitsubishi Xpander Premium", Price = 1000000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "data:image/jpeg;base64," },
                new { Name = "Toyota Veloz Cross", Price = 1100000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "data:image/jpeg;base64," },
                new { Name = "Suzuki XL7 GLX", Price = 900000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "data:image/jpeg;base64," },
                new { Name = "Kia Carens Premium", Price = 1050000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcToEUAaILlZDYiFV1AeBdIA4nXD9k8gQM8wGA&s" },

                // Hàng 5
                new { Name = "VinFast Lux A2.0", Price = 1100000, Year = "2021", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Mazda 3 Premium", Price = 900000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Kia Cerato 2.0", Price = 850000, Year = "2020", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Honda Civic RS", Price = 1200000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },

                // Hàng 6
                new { Name = "Toyota Vios G", Price = 800000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Hyundai Accent ATH", Price = 800000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Kia Morning GT-Line", Price = 600000, Year = "2021", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Hyundai i10 Sedan", Price = 600000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," }
            };
        }

        @foreach (var car in fullList)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden vehicle-card">
                    <div class="position-relative">
                        <img src="@car.Img" class="card-img-top" style="height:210px; object-fit:cover;" alt="@car.Name" onerror="this.src='https://via.placeholder.com/400x250?text=Hao+Hung+Car'" />
                        <span class="position-absolute top-0 start-0 badge bg-primary m-2 shadow-sm">GIAO TẬN NƠI</span>
                    </div>

                    <div class="card-body p-3 text-center">
                        <h6 class="card-title fw-bold text-dark mb-2" style="font-size: 0.95rem; min-height: 2.8rem;">
                            @car.Name
                        </h6>
                        <p class="text-danger fw-bold fs-5 mb-3">
                            @car.Price.ToString("N0")₫
                        </p>
                        
                        <div class="d-flex flex-wrap justify-content-center gap-1 mb-3">
                            <span class="badge-custom bg-info-custom">@car.Year</span>
                            <span class="badge-custom text-muted border">@car.Gear</span>
                            <span class="badge-custom text-muted border">@car.Fuel</span>
                            <span class="badge-custom text-muted border">@car.Seats chỗ</span>
                        </div>
                        
                        <a href="https://zalo.me/0399565529" class="btn btn-outline-success w-100 fw-bold py-2">
                            <i class="bi bi-telephone-fill me-1"></i> Gọi ngay
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .badge-custom { font-size: 0.72rem; padding: 4px 7px; border-radius: 4px; }
    .bg-info-custom { background-color: #007bff !important; color: white !important; }
    .vehicle-card { transition: all 0.3s ease; border: 1px solid #f0f0f0 !important; }
    .vehicle-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; border-color: #007bff !important; }
    .card-title { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<footer style="background-color: #008b8b; color: white;" class="pt-5 pb-3">
    <div class="container text-center">
        <div class="row align-items-center">
            <div class="col-md-4">
                <img src="https://images.turo.com/media/vehicle/images/vDob_s3WTaeCBdsh36dZFA.heic" alt="Logo" style="max-height: 100px;">
                </div>
                <div class="col-md-8">
                    <div class="row">
                        <div class="col-6">
                            <ul class="list-unstyled text-start">
                                <li><a href="#" class="text-white text-decoration-none">Trang chủ</a></li>
                                <li><a href="#" class="text-white text-decoration-none">Liên hệ</a></li>
                                <li><a href="#" class="text-white text-decoration-none">Xe tự lái</a></li>
                            </ul>
                        </div>
                        <div class="col-6">
                            <ul class="list-unstyled text-start">
                                <li><a href="#" class="text-white text-decoration-none">Giới thiệu</a></li>
                                <li><a href="#" class="text-white text-decoration-none">Tin tức & Tư vấn</a></li>
                                <li><a href="#" class="text-white text-decoration-none">Xe có lái</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <hr>
            <p class="small mb-0 fst-italic">Bản quyền © 2026 NamQuanDoanh.com. Thiết kế bởi NKE.com.vn</p>
        </div>
    </footer>
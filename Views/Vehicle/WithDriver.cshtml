@model List<WebApplication1.Models.Vehicle>


@{
    ViewData["Title"] = "Xe có lái";
}

<div class="container-fluid mt-4 px-md-5">
    <h2 class="text-center mb-5 fw-bold" style="color: #333; font-size: 1.5rem; text-transform: uppercase;">Danh sách xe có lái phục vụ tận tình</h2>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @{
            // Danh sách 24 xe có lái khác nhau hoàn toàn
            var coLaiList = new List<dynamic> {
                // Hàng 1: Xe sang phục vụ hội nghị/đám cưới
                new { Name = "Mercedes S450 Luxury", Price = 5000000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "BMW 730Li M-Sport", Price = 4500000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Lexus ES250", Price = 4000000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Audi A8L Premium", Price = 4800000, Year = "2021", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },

                // Hàng 2: SUV gầm cao đi công tác
                new { Name = "Toyota Land Cruiser Prado", Price = 3000000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQKm9lj32_93thSFwv--ddaV8Nc-Qw_uanCKg&s" },
                new { Name = "Ford Everest Platinum", Price = 2200000, Year = "2023", Gear = "Tự động", Fuel = "Dầu", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcR-45affboSmFZYn8ySs72eYCScEc7BvrcnaQ&s" },
                new { Name = "Hyundai SantaFe Caligraphy", Price = 1800000, Year = "2024", Gear = "Tự động", Fuel = "Dầu", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQiII5kS8TAZxJCSQnSf7JHr2IsPp0TBTrSCw&s" },
                new { Name = "Kia Sorento Signature", Price = 1700000, Year = "2023", Gear = "Tự động", Fuel = "Dầu", Seats = 7, Img = "data:image/jpeg;base64," },

                // Hàng 3: MPV gia đình & đưa đón sân bay
                new { Name = "Kia Carnival Royal", Price = 2800000, Year = "2024", Gear = "Tự động", Fuel = "Dầu", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQxHz9lmkrUPqxghyx-sfAagWjdj1zAXe5cdA&s" },
                new { Name = "Toyota Alphard Luxury", Price = 5500000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQc6B1tHgpAzRpsIRfXr-ozdbXSe1vwfup13w&s" },
                new { Name = "Peugeot Traveller Premium", Price = 2000000, Year = "2022", Gear = "Tự động", Fuel = "Dầu", Seats = 7, Img = "data:image/jpeg;base64," },
                new { Name = "Hyundai Starex 9 chỗ", Price = 1500000, Year = "2021", Gear = "Số sàn", Fuel = "Dầu", Seats = 9, Img = "data:image/jpeg;base64," },

                // Hàng 4: Xe du lịch 16 chỗ
                new { Name = "Ford Transit Luxury", Price = 1800000, Year = "2023", Gear = "Số sàn", Fuel = "Dầu", Seats = 16, Img = "data:image/jpeg;base64," },
                new { Name = "Hyundai Solati Premium", Price = 2200000, Year = "2023", Gear = "Số sàn", Fuel = "Dầu", Seats = 16, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcShpKSRPUMuHX-H3IJAXlrgbPrVqFXCMpTjVQ&s" },
                new { Name = "Toyota Hiace 15 chỗ", Price = 1600000, Year = "2021", Gear = "Số sàn", Fuel = "Dầu", Seats = 15, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTqHgI-t7R5pSZ4b8bJpOBTrUu_3jtdLri6bg&s" },
                new { Name = "Mercedes Sprinter", Price = 1700000, Year = "2020", Gear = "Số sàn", Fuel = "Dầu", Seats = 16, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSydt_LRZv9phGppNG5_mmHZN2sFzsDAU7pxw&s" },

                // Hàng 5: Sedan hạng D sang trọng
                new { Name = "Toyota Camry 2.5Q", Price = 1600000, Year = "2024", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Honda Accord Turbo", Price = 1500000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Mazda 6 Premium", Price = 1300000, Year = "2022", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Kia K5 GT-Line", Price = 1400000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },

                // Hàng 6: Xe phổ thông giá rẻ
                new { Name = "Mitsubishi Xpander", Price = 1100000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcReAeKPFD4TKSP3qLkc1-oOkfufrU22otSSOA&s" },
                new { Name = "Toyota Innova Cross", Price = 1300000, Year = "2024", Gear = "Tự động", Fuel = "Xăng", Seats = 7, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQAf33q8buI_mpAQLu4sUaNzx2zSwmV_yMOzw&s" },
                new { Name = "Hyundai Accent ATH", Price = 900000, Year = "2023", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "data:image/jpeg;base64," },
                new { Name = "Toyota Vios G", Price = 900000, Year = "2024", Gear = "Tự động", Fuel = "Xăng", Seats = 5, Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRME1PYb2D_JJFOSDTBndfvXU6tq-GV7Fbf7g&s" }
            };
        }

        @foreach (var car in coLaiList)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden vehicle-card">
                    <div class="position-relative">
                        <img src="@car.Img" class="card-img-top" style="height:210px; object-fit:cover;" alt="@car.Name" onerror="this.src='https://via.placeholder.com/400x250?text=Hao+Hung+Car'" />
                        <span class="position-absolute top-0 start-0 badge bg-primary m-2 shadow-sm">GIAO TẬN NƠI</span>
                    </div>

                    <div class="card-body p-3 text-center">
                        <h6 class="card-title fw-bold text-dark mb-2" style="font-size: 0.95rem; min-height: 2.8rem;">
                            @car.Name
                        </h6>
                        <p class="text-danger fw-bold fs-5 mb-3">
                            @car.Price.ToString("N0")₫
                        </p>
                        
                        <div class="d-flex flex-wrap justify-content-center gap-1 mb-3">
                            <span class="badge-custom bg-info-custom">@car.Year</span>
                            <span class="badge-custom text-muted border">@car.Gear</span>
                            <span class="badge-custom text-muted border">@car.Fuel</span>
                            <span class="badge-custom text-muted border">@car.Seats chỗ</span>
                        </div>
                        
                        <a href="https://zalo.me/0399565529" class="btn btn-outline-success w-100 fw-bold py-2">
                            <i class="bi bi-telephone-fill me-1"></i> Gọi ngay
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .badge-custom { font-size: 0.72rem; padding: 4px 7px; border-radius: 4px; }
    .bg-info-custom { background-color: #007bff !important; color: white !important; }
    .vehicle-card { transition: all 0.3s ease; border: 1px solid #f0f0f0 !important; }
    .vehicle-card:hover { transform: translateY(-8px); box-shadow: 0 12px 24px rgba(0,0,0,0.15) !important; border-color: #28a745 !important; }
    .card-title { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<footer style="background-color: #008b8b; color: white;" class="pt-5 pb-3">
    <div class="container text-center">
        <div class="row align-items-center">
            <div class="col-md-4">
                <img src="https://images.turo.com/media/vehicle/images/vDob_s3WTaeCBdsh36dZFA.heic" alt="Logo" style="max-height: 100px;">
                </div>
                <div class="col-md-8">
                    <div class="row">
                        <div class="col-6">
                            <ul class="list-unstyled text-start">
                                <li><a href="#" class="text-white text-decoration-none">Trang chủ</a></li>
                                <li><a href="#" class="text-white text-decoration-none">Liên hệ</a></li>
                                <li><a href="#" class="text-white text-decoration-none">Xe tự lái</a></li>
                            </ul>
                        </div>
                        <div class="col-6">
                            <ul class="list-unstyled text-start">
                                <li><a href="#" class="text-white text-decoration-none">Giới thiệu</a></li>
                                <li><a href="#" class="text-white text-decoration-none">Tin tức & Tư vấn</a></li>
                                <li><a href="#" class="text-white text-decoration-none">Xe có lái</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <hr>
            <p class="small mb-0 fst-italic">Bản quyền © 2026 NamQuanDoanh.com. Thiết kế bởi NKE.com.vn</p>
        </div>
    </footer>
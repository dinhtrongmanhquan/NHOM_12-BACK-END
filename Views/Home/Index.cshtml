@model WebApplication1.Models.HomeViewModel

@{
    ViewData["Title"] = "Thuê Xe Tự Lái Hà Nội - Nam Quân Doanh";
}

<!-- Hero Banner Carousel -->
<div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=1920&q=80" class="d-block w-100" alt="Lexus 1" style="height:80vh; object-fit:cover;">
            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center h-100 text-center" style="background: rgba(0,0,0,0.4);">
                <h1 class="display-3 fw-bold text-warning text-uppercase">CHO THUÊ XE TỰ LÁI</h1>
                <p class="fs-3 text-danger fw-bold">NHẬN HỢP ĐỒNG DU LỊCH - DỊCH VỤ UY TÍN - CHẤT LƯỢNG - HOÀN HẢO</p>
                <p class="fs-4 text-white">HOTLINE: <span class="text-danger">0399 56 55 29</span></p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1494905998402-395d579af36f?w=1920&q=80" class="d-block w-100" alt="Lexus 2" style="height:80vh; object-fit:cover;">
            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center h-100 text-center" style="background: rgba(0,0,0,0.4);">
                <h1 class="display-3 fw-bold text-warning">XE SANG - XE ĐẸP</h1>
                <p class="fs-3 text-danger fw-bold">LEXUS - MERCEDES - BMW - TOYOTA</p>
                <p class="fs-4 text-white">Liên hệ ngay: 0399 56 55 29</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1552519507-da3b142c6e3d?w=1920&q=80" class="d-block w-100" alt="Lexus 3" style="height:80vh; object-fit:cover;">
            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center h-100 text-center" style="background: rgba(0,0,0,0.4);">
                <h1 class="display-3 fw-bold text-warning">THUÊ XE TỰ LÁI UY TÍN</h1>
                <p class="fs-3 text-danger fw-bold">Giao tận nơi - Giá tốt nhất</p>
                <p class="fs-4 text-white">HOTLINE: 039 956 5529 / 0968 19 66 68</p>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<!-- Danh sách xe -->
<section class="container-fluid my-5 px-md-5">
    <h2 class="text-center mb-5 fw-bold" style="color: #333; font-size: 1.5rem; text-transform: uppercase;">DANH SÁCH XE TỰ LÁI CHO THUÊ</h2>
    
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @{
            var displayVehicles = new List<dynamic> {
                // Hàng 1 (Dữ liệu cũ hoặc mẫu)
                new { Name = "Mercedes Benz E Class E300 AMG -2021", Price = 6000000, Image = "data:image/jpeg;base64,", Year = "2021", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 5, HomeDelivery = true },
                new { Name = "Hyundai Tucson 2.0 ATH 2022", Price = 1350000, Image = "data:image/jpeg;base64,", Year = "2022", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 5, HomeDelivery = false },
                new { Name = "Kia Carnival", Price = 2300000, Image = "data:image/jpeg;base64,", Year = "2024", Transmission = "Số tự động", Fuel = "Máy dầu", Seats = 8, HomeDelivery = true },
                new { Name = "Toyota Fortuner", Price = 1350000, Image = "data:image/jpeg;base64,", Year = "2022", Transmission = "Số tự động", Fuel = "Máy dầu", Seats = 7, HomeDelivery = false },
                // THÊM 7 XE MỚI Ở ĐÂY
                new { Name = "Mazda CX-5 Premium", Price = 1200000, Image = "data:image/jpeg;base64,", Year = "2021", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 5, HomeDelivery = true },
                new { Name = "Vinfast Lux A2.0 Plus", Price = 1100000, Image = "data:image/jpeg;base64,", Year = "2022", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 5, HomeDelivery = true },
                new { Name = "Honda CR-V LSE", Price = 1500000, Image = "data:image/jpeg;base64,", Year = "2022", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 7, HomeDelivery = false },
                new { Name = "Mitsubishi Xpander Premium", Price = 900000, Image = "data:image/jpeg;base64,", Year = "2023", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 7, HomeDelivery = true },
                new { Name = "Kia Cerato 2.0 Premium", Price = 900000, Image = "data:image/jpeg;base64,", Year = "2020", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 5, HomeDelivery = false },
                new { Name = "Toyota Vios G 2023", Price = 800000, Image = "data:image/jpeg;base64,", Year = "2023", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 5, HomeDelivery = true },
                new { Name = "Hyundai Accent ATH", Price = 800000, Image = "data:image/jpeg;base64,", Year = "2022", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 5, HomeDelivery = false },
                new { Name = "Honda city", Price = 1800000, Image = "data:image/jpeg;base64,", Year = "2018", Transmission = "Số tự động", Fuel = "Máy xăng", Seats = 5, HomeDelivery = false }
                
            };
        }

        @foreach (var vehicle in displayVehicles)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden vehicle-card">
                    <div class="position-relative">
                        <img src="@vehicle.Image" class="card-img-top" alt="@vehicle.Name" style="height: 220px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/400x250?text=Hao+Hung+Car'">
                        @if (vehicle.HomeDelivery)
                        {
                            <span class="position-absolute top-0 start-0 badge bg-primary m-2 shadow-sm">GIAO TẬN NƠI</span>
                        }
                    </div>

                    <div class="card-body p-3">
                        <h6 class="card-title fw-bold text-dark mb-2" style="font-size: 1rem; min-height: 2.4rem;">
                            @vehicle.Name
                        </h6>
                        <p class="text-danger fw-bold fs-5 mb-3">
                            @vehicle.Price.ToString("N0")₫
                        </p>
                        
                        <div class="d-flex flex-wrap gap-1">
                            <span class="badge-custom bg-primary">@vehicle.Year</span>
                            <span class="badge-custom text-muted border">@vehicle.Transmission</span>
                            <span class="badge-custom text-muted border">@vehicle.Fuel</span>
                            <span class="badge-custom text-muted border">@vehicle.Seats chỗ</span>
                        </div>
                    </div>

                    <div class="card-footer border-0 bg-white p-3 pt-0">
                        <a href="https://zalo.me/0399565529" class="btn btn-outline-success w-100 fw-bold py-2">
                            <i class="bi bi-telephone-fill me-1"></i> Gọi ngay
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<style>
    .badge-custom {
        font-size: 0.75rem;
        padding: 4px 8px;
        border-radius: 4px;
        display: inline-block;
        margin-bottom: 4px;
    }
    .bg-primary { background-color: #007bff !important; color: #fff; }
    .vehicle-card { transition: all 0.3s ease; }
    .vehicle-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.15) !important;
    }
    .card-title {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<!-- Phần Giới thiệu công ty -->
<section class="container my-5">
    <div class="row">
        <div class="col-lg-8">
            <h2 class="text-primary fw-bold">GIỚI THIỆU CÔNG TY THUÊ XE NAM QUÂN DOANH</h2>
            <p>Chuyên cung cấp dịch vụ thuê xe tự lái - có lái gồm:</p>
            <ul class="list-unstyled">
                <li>✅ Dòng xe 4 chỗ số tự động như Honda, Hyundai, Toyota, Kia đời mới các loại màu đen, trắng, bạc... Quý khách có thể lựa chọn theo nhu cầu công việc, sở thích cá nhân...</li>
                <li>✅ Các dòng xe 7 chỗ phục vụ gia đình, cơ quan công tác đi đường xa, đường núi như Honda, Hyundai, Toyota, Kia... đời mới, máy lạnh tốt, êm ái sẽ mang lại cho quý khách cảm giác ấn tượng khó quên.</li>
                <li>✅ Dòng xe mini bus 16 chỗ Mercedes Sprinter, Ford Transit, Toyota Hiace phục vụ quý khách đi lễ hội, thăm quan, nghỉ mát với kỳ nghỉ thoải mái, vui vẻ.</li>
                <li>✅ Các dòng xe lớn Hyundai 24-30 chỗ, Hyundai Universe và AeroSpace 45-50 chỗ model mới nhất luôn sẵn sàng đáp ứng mọi yêu cầu của khách hàng.</li>
            </ul>
        </div>
        <div class="col-lg-4">
            <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=800" class="img-fluid rounded shadow" alt="Xe sang NAM QUÂN DOANH">
            <p class="text-center mt-2 text-danger fw-bold">HOTLINE: 039 956 5529 / 0968 19 66 68</p>
        </div>
    </div>
</section>

<!-- Phần Tin tức & Tư vấn (grid 5 card) -->
<section class="bg-light py-5">
    <div class="container-fluid px-4">
        <h2 class="text-center mb-5 fw-bold" style="color: #333; font-size: 1.5rem;">TIN TỨC & TƯ VẤN</h2>
        
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-3">
            @{
                // Tạo dữ liệu mẫu liên quan đến thuê xe
                var dummyNews = new[] {
                    new { Title = "HAPPY NEW YEAR - XUÂN BÍNH NGỌ 2026!", Img = "data:image/jpeg;base64," },
                    new { Title = "CHÚC MỪNG NGHỈ LỄ QUỐC KHÁNH 2/9/2024", Img = "https://xetulaih2.com/wp-content/uploads/lich-nghi-le-quoc-khanh-29-800x800-1-768x768.jpg" },
                    new { Title = "Danh sách các mức xử phạt ô tô thường gặp 2026", Img = "https://xetulaih2.com/wp-content/uploads/tong-hop-cac-muc-xu-phat-o-to-thuong-gap-nhat-moi-cap-nhat.jpg" },
                    new { Title = "Những đoạn đường lắp camera phạt nguội ở Hà Nội", Img = "https://xetulaih2.com/wp-content/uploads/Nhung-doan-duong-lap-camera-phat-nguoi-o-Ha-Noi-moi-nhat.jpg" },
                    new { Title = "Kinh nghiệm thuê xe tự lái dịp lễ tết tránh bị ép giá", Img = "data:image/jpeg;base64," },
                    new { Title = "Thuê xe tự lái - Tự do khám phá và di chuyển tại Hà Nội", Img = "https://xetulaih2.com/wp-content/uploads/thue-xe-tu-lai-tu-do-kham-pha-va-di-chuyen-tai-ha-noi.jpg" },
                    new { Title = "Khám phá Hà Nội tự do và tiện lợi với dịch vụ uy tín", Img = "https://xetulaih2.com/wp-content/uploads/kham-pha-ha-noi-tu-do-va-tien-loi-voi-dich-vu-thue-xe-tu-lai-uy-tin-768x547.jpg" },
                    new { Title = "Những điều cần biết khi lái xe số tự động cho người mới", Img = "https://xetulaih2.com/wp-content/uploads/nhung-dieu-can-biet-khi-lai-xe-so-tu-dong-cho-nguoi-moi-bat-dau.jpg" },
                    new { Title = "Dịch vụ thuê xe tự lái giá rẻ uy tín tại Hà Nội", Img = "https://xetulaih2.com/wp-content/uploads/dich-vu-thue-xe-tu-lai-gia-re-uy-tin-tai-ha-noi-768x418.jpg" },
                    new { Title = "Thuê xe ô tô giá rẻ, uy tín ở đâu tại Hà Nội?", Img = "https://xetulaih2.com/wp-content/uploads/bn-gioi-thieu.jpg" }
                };
            }

            @foreach (var item in dummyNews)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden">
                        <div style="height: 140px; overflow: hidden;">
                            <img src="@item.Img" 
                                 class="card-img-top h-100 w-100" 
                                 alt="@item.Title" 
                                 style="object-fit: cover;"
                                 onerror="this.src='https://via.placeholder.com/400x300?text=Hao+Hung+Car'">
                        </div>
                        <div class="card-body p-2">
                            <h6 class="card-title mb-1 text-dark fw-bold" style="font-size: 0.85rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.Title.ToUpper()
                            </h6>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    .card { transition: transform 0.2s; cursor: pointer; }
    .card:hover { transform: scale(1.03); shadow: 0 10px 20px rgba(0,0,0,.12); }
</style>

<style>
    /* Hiệu ứng khi di chuột vào card cho chuyên nghiệp */
    .card {
        transition: transform 0.2s ease-in-out;
        cursor: pointer;
    }
    .card:hover {
        transform: translateY(-5px);
    }
    /* Đảm bảo tiêu đề không quá dài làm lệch layout */
    .card-title {
        display: -webkit-box;
        -webkit-line-clamp: 3; /* Giới hạn 3 dòng chữ */
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<!-- Phần Dịch vụ bằng lái xe quốc tế -->
<section class="container my-5">
    <div class="row">
        <div class="col-lg-8">
            <h2 class="text-primary fw-bold">DỊCH VỤ LÀM BẰNG LÁI XE QUỐC TẾ - UY TÍN & GIÁ RẺ</h2>
            <p>Dành cho những ai muốn chủ động lái xe (ô tô, xe máy) khi đi du lịch, công tác, sinh sống, học tập hoặc làm việc... tại nước ngoài.</p>
            <ul class="list-unstyled">
                <li>✅ Có 29 ngôn ngữ, được phép lái xe tại 201 nước.</li>
                <li>✅ Đăng ký qua mạng mà không cần đi thi, khám sức khỏe hay giấy tờ tùy thân...</li>
                <li>✅ Tổng chi phí đăng ký chưa tới 100$.</li>
                <!-- Thêm các bullet còn lại từ text bạn -->
            </ul>
            <p class="mt-3">Quý khách có nhu cầu xin liên hệ Hotline: 0399.56.55.29</p>
        </div>
    </div>
</section>

<!-- Phần Ý kiến khách hàng -->
<section class="py-5" style="background-color: #f9f9f9;">
    <div class="container">
        <div class="d-flex align-items-center justify-content-center mb-5">
            <div style="flex: 1; height: 1px; background: #ccc;"></div>
            <h2 class="mx-4 fw-bold mb-0" style="font-size: 1.5rem; color: #333;">Ý KIẾN KHÁCH HÀNG</h2>
            <div style="flex: 1; height: 1px; background: #ccc;"></div>
        </div>

        <div class="row">
            @{
                var reviews = new[] {
                    new { Name = "Phạm Hoàng", Role = "Giám đốc công ty", Content = "Tôi ưng thuê xe tháng tại đây vì anh em tư vấn nhiệt tình và có tâm, chính sách thuê rõ ràng sòng phẳng, nhiệt tình hỗ trợ khi có sự cố xe hoặc phạt nguội..." },
                    new { Name = "Lan Anh", Role = "Nhân viên lễ tân", Content = "Mỗi lần thuê xe bên công ty Nam Quân Doanh thấy rất sạch sẽ, thơm tho nên mấy đứa nhóc nhà em rất thích, mỗi lần cả nhà về quê đều thuê xe tại đây..." },
                    new { Name = "Lê Thành Hưng", Role = "Trưởng phòng", Content = "Có việc cần thuê xe gấp trong đêm nhưng gọi mãi không có ai, may mắn được công ty Nam Quân Doanh hỗ trợ nhiệt tình giúp tôi kịp thời xử lý công việc..." }
                };
            }

            @foreach (var item in reviews)
            {
                <div class="col-md-4 px-4 position-relative testimonial-item">
                    <div class="text-center">
                        <p class="mb-4 text-dark fw-medium" style="line-height: 1.6; font-size: 0.95rem; min-height: 90px;">
                            "@item.Content"
                        </p>

                        <div class="mt-3">
                            <h6 class="mb-0 fw-bold" style="color: #000; font-size: 1rem;">@item.Name</h6>
                            <small class="text-muted fst-italic" style="font-size: 0.85rem;">@item.Role</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    /* Đường kẻ dọc giữa các cột */
    @@media (min-width: 768px) {
        .testimonial-item:not(:last-child)::after {
            content: "";
            position: absolute;
            right: 0;
            top: 15%;
            height: 70%;
            width: 1px;
            background-color: #ddd;
        }
    }
</style>

<!-- Phần Đối tác -->
<section class="py-5" style="background-color: #fff;">
    <div class="container">
        <div class="d-flex align-items-center justify-content-center mb-5">
            <div style="flex: 1; height: 1px; background: #ccc;"></div>
            <h2 class="mx-4 fw-bold mb-0" style="font-size: 1.5rem; color: #333; white-space: nowrap;">ĐỐI TÁC CỦA CHÚNG TÔI</h2>
            <div style="flex: 1; height: 1px; background: #ccc;"></div>
        </div>

        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3 justify-content-center">
            @{
                // Danh sách logo các hãng xe (Bạn có thể thay link ảnh thật của bạn vào đây)
                var partners = new[] {
                    new { Name = "KIA", Logo = "https://xetulaih2.com/wp-content/uploads/elementor/thumbs/doitac01-qodwljzmav96ee5jwo1vg5iggch160eohxagldbeos.jpg" },
                    new { Name = "MAZDA", Logo = "https://xetulaih2.com/wp-content/uploads/elementor/thumbs/doitac02-qodwljzmav96ee5jwo1vg5iggch160eohxagldbeos.jpg" },
                    new { Name = "TOYOTA", Logo = "https://xetulaih2.com/wp-content/uploads/elementor/thumbs/doitac03-qodwljzmav96ee5jwo1vg5iggch160eohxagldbeos.jpg" },
                    new { Name = "NISSAN", Logo = "https://xetulaih2.com/wp-content/uploads/elementor/thumbs/doitac04-qodwljzmav96ee5jwo1vg5iggch160eohxagldbeos.jpg" },
                    new { Name = "HONDA", Logo = "https://upload.wikimedia.org/wikipedia/commons/thumb/3/38/Honda.svg/1200px-Honda.svg.png" },
                    new { Name = "HYUNDAI", Logo = "https://upload.wikimedia.org/wikipedia/commons/thumb/4/44/Hyundai_Motor_Company_logo.svg/1200px-Hyundai_Motor_Company_logo.svg.png" }
                };
            }

            @foreach (var item in partners)
            {
                <div class="col">
                    <div class="partner-card p-3 border rounded shadow-sm d-flex align-items-center justify-content-center" style="height: 120px; background: #fff;">
                        <img src="@item.Logo" alt="@item.Name" class="img-fluid" style="max-height: 60px; filter: grayscale(20%);">
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    /* Hiệu ứng khi di chuột vào logo */
    .partner-card {
        transition: all 0.3s ease;
        border-color: #eee !important;
    }
    .partner-card:hover {
        border-color: #007bff !important;
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
    }
    .partner-card img {
        transition: all 0.3s ease;
    }
    .partner-card:hover img {
        filter: grayscale(0%);
    }
</style>


    <!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thuê Xe Tự Lái Nam Quân Doanh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <!-- Navbar fixed top -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <!-- Logo -->
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="https://images.turo.com/media/vehicle/images/vDob_s3WTaeCBdsh36dZFA.heic" alt="Logo" width="40" height="40" class="me-2">
                <span>THUÊ XE TỰ LÁI</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <!-- Menu -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        TRANG CHỦ
                    </a>
                    <a class="nav-link" asp-controller="Home" asp-action="About">GIỚI THIỆU</a>
                    <li class="nav-item">
                        <a class="nav-link" href="/Vehicle">XE TỰ LÁI</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Vehicle" asp-action="WithDriver">
                            XE CÓ LÁI
                        </a>
                    </li>
                </ul>

                <!-- Search -->
                <form class="d-flex mx-auto my-2 my-lg-0" style="max-width: 400px;">
                    <input class="form-control me-2" type="search" placeholder="Bạn muốn tìm gì?" aria-label="Search">
                    <button class="btn btn-outline-light" type="submit">🔍</button>
                </form>

                <!-- Hotline button -->
                <a href="tel:0968196668" class="btn btn-danger ms-lg-3 d-flex align-items-center">
                    <span class="me-2">📞</span> 0399.56.5529
                </a>
            </div>
        </div>
    </nav>

    <!-- Main content (push down vì navbar fixed) -->
    <main role="main" style="padding-top: 80px;">
        @RenderBody()
    </main>

    <!-- Floating contact buttons - -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1030;">
        <div class="d-flex flex-column gap-3">
            <a href="tel:0399565529" class="btn btn-primary shadow-lg d-flex align-items-center justify-content-center rounded-circle" style="width:55px; height:55px;">
                <i class="bi bi-telephone-fill fs-4"></i>
            </a>

            <a href="https://zalo.me/0399565529" class="btn btn-info text-white shadow-lg d-flex align-items-center justify-content-center rounded-circle" style="width:55px; height:55px;">
                <i class="bi bi-chat-dots-fill fs-4"></i>
            </a>

            <a href="mailto:namnguyenthe.dev@gmail.com?subject= Liên hệ từ khách hàng thuê xe"
                   class="btn btn-warning text-white shadow-lg d-flex align-items-center justify-content-center rounded-circle"
                   style="width:55px; height:55px;">
                <i class="bi bi-envelope-at-fill fs-4"></i>
            </a>
        </div>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>